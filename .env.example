# Copy to .env.local and fill in from Firebase console → Project settings → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Email domain restriction for sign-in (without leading @)
VITE_ALLOWED_EMAIL_DOMAIN=punx.ai

# Super-admin bootstrap: comma-separated emails that auto-become super_admin on first sign-in
VITE_SUPER_ADMIN_EMAILS=rey@punx.ai
